{
  "manifest_version": 3,
  "name": "Auto-PrairieLearn",
  "version": "1.0",
  "description": "Transfers PrairieLearn multiple-choice questions to AI assistants and optionally auto-grades the selected answer.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": [
    "https://*/pl/course_instance/*/instance_question/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://deepseek.chat/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {
    "48": "assets/icon.png"
  },
  "action": {
    "default_popup": "popup/settings.html",
    "default_icon": "assets/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/pl/course_instance/*/instance_question/*"],
      "js": ["content-scripts/prairielearn.js"]
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content-scripts/chatgpt.js"]
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content-scripts/gemini.js"]
    },
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://deepseek.chat/*"
      ],
      "js": ["content-scripts/deepseek.js"]
    }
  ]
}
